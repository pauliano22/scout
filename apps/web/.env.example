# Supabase Configuration
# Get these from your Supabase project dashboard: https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# For server-side operations (optional, for admin functions)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Claude API for AI-generated messages (optional)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Resend API for instant password reset emails
RESEND_API_KEY=your_r..._key

# Anthropic Claude API for AI-powered message drafting (agent feature)
# Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=your_a..._key

# OpenAI API key for embeddings + semantic search (agent + search features)
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_o..._key

# Agent Configuration
# --------------------
# Shared secret that authenticates the Vercel Cron /api/agent/tick endpoint.
# Must match the value in Vercel Cron Jobs → Headers.
CRON_SECRET=your_cron_secret_here

# Comma-separated list of user UUIDs enrolled in the agent pilot.
# The agent loop ONLY processes these users. Leave empty to keep the loop inert.
AGENT_PILOT_USER_IDS=uuid_1,uuid_2

# People Data Labs enrichment (get from peopledatalabs.com)
PDL_API_KEY=your_pdl_api_key

# PostHog Analytics (get from posthog.com → Project Settings → API Keys)
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
