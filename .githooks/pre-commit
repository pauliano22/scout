#!/bin/sh
# pre-commit: Prevent accidental commits of secrets, API keys, tokens, and
# sensitive process.env references in console.log/console.error calls.
#
# Installation: git config core.hooksPath .githooks

set -e

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo "🔍 Scanning staged files for potential secrets..."

# ---------------------------------------------------------------------------
# 1. Secret patterns — API keys, tokens, credentials
# ---------------------------------------------------------------------------
# Value-signature patterns only — these match actual leaked credentials, not
# env-var names. Bare-name patterns (SUPABASE_URL, DATABASE_URL, service_role,
# *_KEY as identifiers) were removed: they false-positive on every legitimate
# process.env reference and never indicate a real leak. The JWT pattern leads
# because a hard-coded Supabase service-role JWT is the leak this repo had.
# NOTE: the scan loop word-splits these, so every token must be space-free
# (use "." to match a literal space, as in the PEM patterns below).
SECRET_PATTERNS="
eyJ[A-Za-z0-9_=-]{8,}\.eyJ[A-Za-z0-9_=-]{8,}\.[A-Za-z0-9_=-]{8,}
sk-ant-[a-zA-Z0-9_-]{20,}
sk-[a-zA-Z0-9]{20,}
sk_live_[0-9a-zA-Z]{20,}
sk_test_[0-9a-zA-Z]{20,}
pk_live_[0-9a-zA-Z]{20,}
pk_test_[0-9a-zA-Z]{20,}
whsec_[0-9a-zA-Z]{16,}
SG\.[a-zA-Z0-9_-]{20,}
re_[a-zA-Z0-9]{20,}
xox[baprs]-[a-zA-Z0-9-]{10,}
gh[pousr]_[a-zA-Z0-9]{20,}
AIza[0-9A-Za-z_-]{30,}
AKIA[0-9A-Z]{16}
-----BEGIN.PRIVATE.KEY-----
-----BEGIN.(RSA|EC|DSA|OPENSSH|PGP).PRIVATE.KEY-----
api[_-]?key[=:][[:space:]]*['\"][a-zA-Z0-9_\-]{16,}
secret[_-]?key[=:][[:space:]]*['\"][a-zA-Z0-9_\-]{16,}
service[_-]?role[_-]?key[=:][[:space:]]*['\"][a-zA-Z0-9_\-]{16,}
client[_-]?secret[=:][[:space:]]*['\"][a-zA-Z0-9_\-]{16,}
bearer[[:space:]]+[A-Za-z0-9_\-]{24,}
"

# ---------------------------------------------------------------------------
# 2. Process.env in console.log / console.error
# ---------------------------------------------------------------------------
CONSOLE_ENV_PATTERN="console\.(log|error|warn|debug)\s*\([^)]*process\.env"

violations=""

# Get list of staged files (only added/modified, not deleted)
staged_files=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$staged_files" ]; then
  echo "✅ No staged files to scan."
  exit 0
fi

check_pattern_in_file() {
  file="$1"
  pattern="$2"
  label="$3"
  matches=$(git diff --cached -G"$pattern" -- "$file" 2>/dev/null | grep -E "$pattern" | head -5 || true)
  if [ -n "$matches" ]; then
    violations="${violations}\n  ⚠️  $file — $label"
  fi
}

check_console_env() {
  file="$1"
  matches=$(git diff --cached -G"$CONSOLE_ENV_PATTERN" -- "$file" 2>/dev/null | grep -oE "$CONSOLE_ENV_PATTERN" | head -5 || true)
  if [ -n "$matches" ]; then
    violations="${violations}\n  ⚠️  $file — process.env reference in console.log/error output"
  fi
}

for file in $staged_files; do
  # Skip binary, image, lock files, and scanner definition files
  case "$file" in
    *.png|*.jpg|*.jpeg|*.gif|*.ico|*.svg|*.woff|*.woff2|*.ttf|*.eot|*.lock|package-lock.json|yarn.lock|pnpm-lock.yaml)
      continue
      ;;
    .githooks/pre-commit|.github/workflows/secret-scan.yml)
      continue
      ;;
  esac

  # Only scan text-like files
  mime=$(git show :"$file" 2>/dev/null | file - --mime-type 2>/dev/null | awk '{print $2}' | cut -d/ -f1 || echo "unknown")
  if [ "$mime" != "text" ] && [ "$mime" != "application" ]; then
    continue
  fi

  # Check secret patterns line by line
  content=$(git show :"$file" 2>/dev/null || true)
  if [ -z "$content" ]; then
    continue
  fi

  # Check each secret pattern
  echo "$SECRET_PATTERNS" | while IFS= read -r pattern; do
    [ -z "$pattern" ] && continue
    if echo "$content" | grep -Eq "$pattern" 2>/dev/null; then
      echo "$pattern" > /dev/null  # pass — we'll collect below
    fi
  done

  # Simpler: use grep directly on staged content for key patterns
  for pattern in $(echo "$SECRET_PATTERNS" | grep -v '^$'); do
    matched=$(echo "$content" | grep -Eon "$pattern" 2>/dev/null | head -3 || true)
    if [ -n "$matched" ]; then
      # Get line numbers
      line_nums=$(echo "$matched" | cut -d: -f1 | paste -sd, -)
      if [ -z "$violations" ]; then
        violations="\n"
      fi
      violations="${violations}  ⚠️  $file (line $line_nums) — matched pattern: $(echo "$pattern" | head -c 40)...\n"
      # Break after first pattern match per file to reduce noise
      break
    fi
  done

  # Check for process.env in console.log/error
  console_matches=$(echo "$content" | grep -Eon "$CONSOLE_ENV_PATTERN" 2>/dev/null | head -3 || true)
  if [ -n "$console_matches" ]; then
    line_nums=$(echo "$console_matches" | cut -d: -f1 | paste -sd, -)
    if [ -z "$violations" ]; then
      violations="\n"
    fi
    violations="${violations}  ⚠️  $file (line $line_nums) — process.env in console.log/error output\n"
  fi
done

if [ -n "$violations" ]; then
  echo ""
  echo "${RED}❌ SECRET LEAK DETECTED${NC}"
  echo "${RED}━━━━━━━━━━━━━━━━━━━━━━${NC}"
  printf "%b" "$violations"
  echo ""
  echo "${YELLOW}⚠️  Commit blocked. Remove or replace these secrets before committing.${NC}"
  echo "${YELLOW}  - Use environment variables (process.env.X) instead of hard-coded values.${NC}"
  echo "${YELLOW}  - Never commit .env.local files or API keys.${NC}"
  echo "${YELLOW}  - If you need to add a new secret, see docs/secrets.md.${NC}"
  echo ""
  echo "${YELLOW}To bypass this check (not recommended): git commit --no-verify${NC}"
  exit 1
fi

echo "✅ No secrets detected in staged files."
exit 0
