# Sentry Error Monitoring
# Get your DSN from https://sentry.io/settings/projects/<project>/keys/
NEXT_PUBLIC_SENTRY_DSN=https://example@example.ingest.sentry.io/project

# Vercel Environment (auto-set by Vercel, default for local dev)
NEXT_PUBLIC_VERCEL_ENV=development

# Telegram moderation alerts — real-time ping when an alumni profile is flagged.
# Both must be set (in apps/web/.env.local locally, and in your prod env) or the
# alert is a silent no-op (shared with claim alerts). Bot token from @BotFather;
# chat id from @userinfobot (your DM) or the group's id. See lib/notify/telegram.ts.
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
TELEGRAM_CHAT_ID=123456789

# Contact-consent enforcement (DPA). When 'true', alumni email/linkedin_url are
# stripped from student-facing responses unless the alum claimed their profile
# AND opted in via share_email_with_students. Unset/other = current behavior.
# See apps/web/lib/privacy/sanitizeAlumni.ts.
ENFORCE_CONTACT_CONSENT=false
