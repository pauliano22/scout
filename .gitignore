# Scripts — broad ignore for ad-hoc operational tooling. The `apps/web/scripts/`
# directory is reachable so individual feature scripts can be un-ignored below;
# everything inside it is still ignored by default.
scripts/*
!apps/web/scripts/
apps/web/scripts/*
# Exception: feature-code scripts that the repo needs to ship.
!apps/web/scripts/index-alumni-embeddings.ts
!apps/web/scripts/hermes-bridge.py
!apps/web/scripts/security-scan.sh
!apps/web/scripts/pii-endpoint-audit.ts
!apps/web/scripts/dedup-alumni.ts
!apps/web/scripts/README.md
# Exception: root-level CI/CD helper scripts
!scripts/smoke-test.sh
!scripts/restore-from-backup.mjs
.env*

# local backup snapshots (PII — never commit; repo is public)
backups/
